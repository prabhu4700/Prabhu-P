

class User:
    def __init__(self, name):
        self.name = name
        self.help_given = 0
        self.help_received = 0

    def give_help(self, other_user):
        print(self.name, "helps", other_user.name)
        self.help_given += 1
        other_user.help_received += 1

    def show_status(self):
        print("\nUser:", self.name)
        print("Help Given:", self.help_given)
        print("Help Received:", self.help_received)


# Create users
user1 = User("Alice")
user2 = User("Bob")
user3 = User("Charlie")

# Simulating reciprocity
user1.give_help(user2)
user2.give_help(user1)

user2.give_help(user3)
user3.give_help(user2)

user1.give_help(user3)
user3.give_help(user1)

# Show final status
user1.show_status()
user2.show_status()
user3.show_status()
